@article{miske2026,
  title = {Investigating the reproducibility of the social and behavioural sciences},
  author = {Miske, Olivia and Abatayo, Anna Lou and Daley, Mason and Dirzo, Mirka and Fox, Nicholas and Haber, Noah and Hahn, Krystal M. and Struhl, Melissa Kline and Mawhinney, Brinna and Silverstein, Priya and Stankov, Theresa and Tyner, Andrew H. and Adamkovič, Matúš and Alzahawi, Shilaan and Anafinova, Saule and Awtrey, Eli and Axxe, Erick and Bailey, James and Bakker, Bert N. and Balaji, Akshaya and Banik, Gabriel and Bartoš, František and Berkman, Henk and Berry, Zachariah and Bethke, Felix S. and Brady, Timothy F. and Breznau, Nate and Capitan, Sara and Capitán, Tabaré and Caquelin, Laura and Cheng, Kent Jason and Chopik, William J. and Clochard, Gwen-Jiro and Coupé, Tom and Cummins, Jamie and Burak, Elif Gizem Demirag and Duan, Jianhua and Esterling, Kevin M. and Evans, Thomas R. and Fiala, Nathan and Field, James and Gay, Victor and Geng, Jing and Gereke, Johanna and Gleibs, Ilka Helene and Gourdon-Kanhukamwe, Amélie and Grigoryev, Dmitry and Gunby, Nicholas and Hanel, Paul H. P. and Hong, Sanghyun and Houlihan, Sean Dae and Huntington-Klein, Nick and Izydorczak, Kamil and Jankowsky, Kristin and Jonas, Kai and Kačmár, Pavol and Kapoor, Hansika and Karcher, Sebastian and Kołczyńska, Marta and Kretschmer, David and Lazarevic, Ljiljana and Leahy, Katelin E. and Lee, Jessica C. and Limnios, Christopher and Liu, An-Chiao and Lloyd, John Wills and Lopez-Nicolas, Ruben and Lou, Nigel Mantou and Lucas, Richard E. and Maier, Maximilian and Mallinson, Daniel J. and Martončik, Marcel and McCall, Michael C. and Mehta, Nikita and Méndez, Esteban and Michalak, Johannes and Molden, Daniel C. and Mushtaq, Faisal and Neuendorf, Claudia and Nichols, Austin Lee and Nilsonne, Gustav and O’Boyle, Ernest and Oh, Jeewon and Ostermann, Thomas and Oyebanjo, Abiola and Panczak, Radoslaw and Pavlov, Yuri G. and Pavlović, Zoran and Peter, Noemi and Peters, Kim and Porter, Nathaniel D. and Purol, Mariah and Puthillam, Arathy and Ramljak, Marco and Reader, Arran T. and Reed, W. Robert and Röer, Jan Philipp and Ropovik, Ivan and Savi, Alexander O. and Schmidt, Kathleen and Schnabel, Landon and Sevigny, Eric L. and Shaki, Samuel and Shakya, Shishir and Soh, Andrew and Somo, Angela and Sonmez, Fatih and Strømland, Eirik and Suchow, Jordan W. and Szabelska, Anna and Tagat, Anirudh and Tutor, Melba Verra and Urbanska, Karolina and Van Dessel, Pieter and Vargo, Elisabeth Julie and Vo, Diem Thi Hong and Volkman, Victor and Wang, Ke and Wichman, Aaron L. and Williams, Jamal R. and Winter, Fabian and Wintermantel, Ferdinand and Zhang, Nan and Ziano, Ignazio and Zogmaister, Cristina and Zupan, Zorana and Nosek, Brian A. and Errington, Timothy M.},
  date = {2026-04},
  journaltitle = {Nature},
  volume = {652},
  number = {8108},
  pages = {126--134},
  publisher = {Nature Publishing Group},
  issn = {1476-4687},
  doi = {10.1038/s41586-026-10203-5},
  abstract = {Published claims should be reproducible, yielding the same result when the same analysis is applied~to the same data1,2. Here we assess reproducibility in a stratified random sample of 600 papers published from 2009 to 2018 in 62 journals spanning the social and behavioural sciences. The authors of 144 (24.0\%, 95\% confidence interval (CI)\,=\,20.8–27.6\%) papers made data available to assess reproducibility and, for 38 others, we obtained source data to reconstruct the dataset. We assessed 143 out of the 182 available datasets and found that 76.6 (53.6\%, 95\% CI\,=\,45.8–60.7\%) papers were rated as precisely reproducible and 105.0 (73.5\%, 95\% CI\,=\,66.4–80.0\%) were rated as at~least approximately reproducible (within 15\% of the original effects or within 0.05 of original P values) after inverse weighting each of the 551 claims by the number of claims per paper. We observed higher reproducibility for papers from political science and economics compared with other fields, for more~recent papers compared with older papers and for papers from journals that require data sharing. Implementation of measures to verify that research is reproducible is needed to support trustworthiness in the complex enterprise of knowledge production3,4.},
  langid = {english},
  keywords = {reproducibility,reproducibility crisis,science,scientific community,social sciences}
}

